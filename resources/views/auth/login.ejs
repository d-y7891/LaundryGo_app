<section class="login flex justify-center pt-24">
  <div class="w-full max-w-xs">
    <form action="/login" method="post" class="bg-white shadow-md rounded-2xl px-8 pt-6 pb-8 mb-4">
      <div class="text-center mb-6">
        <div class="text-4xl mb-2">🧺</div>
        <h2 class="text-2xl font-bold">Welcome Back</h2>
        <p class="text-gray-500 text-sm">Sign in to LaundryGo</p>
      </div>
      <% if (messages.error) { %>
      <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-xl mb-4"><%= messages.error %></div>
      <% } %>
      <div class="mb-4">
        <label class="block text-gray-700 text-sm font-bold mb-2">E-mail</label>
        <input name="email" class="shadow appearance-none border rounded-xl w-full py-2 px-3 text-gray-700 focus:outline-none focus:border-purple-400" type="email" placeholder="Email" />
      </div>
      <div class="mb-6">
        <label class="block text-gray-700 text-sm font-bold mb-2">Password</label>
        <input name="password" class="shadow appearance-none border rounded-xl w-full py-2 px-3 text-gray-700 focus:outline-none focus:border-purple-400" type="password" placeholder="******************" />
      </div>
      <div class="flex items-center justify-between">
        <button type="submit" class="btn-primary rounded-full text-white font-bold py-2 px-6">Login</button>
        <a class="font-bold text-sm text-purple-600" href="/register">Create account</a>
      </div>
    </form>
  </div>
</section>
