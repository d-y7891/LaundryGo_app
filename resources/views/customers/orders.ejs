<section class="orders light-section">
  <div class="px-10 container mx-auto pt-12">
    <h1 class="font-bold text-2xl mb-2">My Laundry Orders</h1>
    <p class="text-gray-500 mb-8">Track all your laundry requests</p>

    <% if (messages.success) { %>
    <div id="success-alert" class="flex items-center bg-green-500 text-white text-sm font-bold px-4 py-3 rounded-xl mb-6">
      <svg class="fill-current w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M12.432 0c1.34 0 2.01.912 2.01 1.957 0 1.305-1.164 2.512-2.679 2.512-1.269 0-2.009-.75-1.974-1.99C9.789 1.436 10.67 0 12.432 0zM8.309 20c-1.058 0-1.833-.652-1.093-3.524l1.214-5.092c.211-.814.246-1.141 0-1.141-.317 0-1.689.562-2.502 1.117l-.528-.88c2.572-2.186 5.531-3.467 6.801-3.467 1.057 0 1.233 1.273.705 3.23l-1.391 5.352c-.246.945-.141 1.271.106 1.271.317 0 1.357-.392 2.379-1.207l.6.814C12.098 19.02 9.365 20 8.309 20z"/></svg>
      <p><%= messages.success %></p>
    </div>
    <% } %>

    <% if (orders.length) { %>
    <div class="space-y-4">
      <% orders.forEach(order => { %>
      <div class="bg-white rounded-2xl shadow-sm p-6 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-4">
          <div>
            <span class="text-xs text-gray-400 font-mono">Order #<%= order._id.toString().slice(-8).toUpperCase() %></span>
            <h3 class="font-bold text-gray-800"><%= order.providerId ? (order.providerId.businessName || order.providerId.name) : 'Provider' %></h3>
            <p class="text-sm text-gray-400"><%= moment(order.createdAt).format('DD MMM YYYY, hh:mm A') %></p>
          </div>
          <div class="text-right">
            <span class="status-badge px-3 py-1 rounded-full text-xs font-bold
              <%= order.status === 'completed' ? 'bg-green-100 text-green-700' :
                 order.status === 'cancelled' ? 'bg-red-100 text-red-700' :
                 order.status === 'delivered' ? 'bg-blue-100 text-blue-700' : 'bg-yellow-100 text-yellow-700' %>">
              <%= order.status.replace(/_/g,' ').toUpperCase() %>
            </span>
            <p class="font-bold text-purple-700 mt-2">₹<%= order.totalPrice %></p>
          </div>
        </div>
        <!-- Items Summary -->
        <div class="border-t pt-4 mb-4">
          <% order.items.forEach(item => { %>
          <div class="flex justify-between text-sm text-gray-600 mb-1">
            <span><%= item.serviceName %> × <%= item.quantity %> <%= item.unit %></span>
            <span>₹<%= item.subtotal %></span>
          </div>
          <% }) %>
        </div>
        <div class="flex items-center justify-between">
          <a href="/customer/orders/<%= order._id %>" class="text-purple-600 text-sm font-semibold hover:underline">Track Order →</a>
          <% if (order.status === 'completed' && !order.rating) { %>
          <button class="rate-btn text-sm border border-yellow-400 text-yellow-600 px-4 py-1 rounded-full hover:bg-yellow-50" data-orderid="<%= order._id %>">⭐ Rate Service</button>
          <% } else if (order.rating) { %>
          <span class="text-sm text-yellow-500">⭐ You rated: <%= order.rating %>/5</span>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="text-center py-20">
      <div class="text-6xl mb-4">🧺</div>
      <h2 class="text-xl font-bold mb-2">No orders yet</h2>
      <p class="text-gray-500 mb-6">Find a laundry provider and place your first request!</p>
      <a href="/" class="inline-block btn-primary px-8 py-3 rounded-full text-white font-bold">Find Providers</a>
    </div>
    <% } %>
  </div>
</section>

<!-- Rating Modal -->
<div id="ratingModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6">
    <h2 class="text-xl font-bold mb-4">Rate this Service</h2>
    <div class="flex gap-2 mb-4" id="starContainer">
      <% for(let i=1;i<=5;i++) { %>
      <button class="star-btn text-3xl text-gray-300 hover:text-yellow-400 transition-colors" data-val="<%= i %>">★</button>
      <% } %>
    </div>
    <textarea id="reviewText" placeholder="Write a review (optional)" rows="3" class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:border-purple-400 mb-4"></textarea>
    <input type="hidden" id="ratingOrderId" />
    <div class="flex gap-3">
      <button id="submitRating" class="flex-1 btn-primary text-white py-2 rounded-full font-bold">Submit</button>
      <button id="cancelRating" class="flex-1 border border-gray-300 py-2 rounded-full text-gray-600">Cancel</button>
    </div>
  </div>
</div>

<script>
let selectedRating = 0;
const alertMsg = document.querySelector('#success-alert');
if(alertMsg) setTimeout(() => alertMsg.remove(), 3000);

document.querySelectorAll('.rate-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('ratingOrderId').value = btn.dataset.orderid;
    selectedRating = 0;
    document.querySelectorAll('.star-btn').forEach(s => s.classList.replace('text-yellow-400','text-gray-300'));
    document.getElementById('ratingModal').classList.remove('hidden');
  });
});

document.querySelectorAll('.star-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    selectedRating = +btn.dataset.val;
    document.querySelectorAll('.star-btn').forEach((s,i) => {
      s.classList.toggle('text-yellow-400', i < selectedRating);
      s.classList.toggle('text-gray-300', i >= selectedRating);
    });
  });
});

document.getElementById('cancelRating')?.addEventListener('click', () => {
  document.getElementById('ratingModal').classList.add('hidden');
});

document.getElementById('submitRating')?.addEventListener('click', async () => {
  if (!selectedRating) { alert('Please select a rating'); return; }
  const orderId = document.getElementById('ratingOrderId').value;
  const review = document.getElementById('reviewText').value;
  const res = await fetch('/customer/rate', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ orderId, rating: selectedRating, review })
  });
  if (res.ok) { location.reload(); }
});
</script>
